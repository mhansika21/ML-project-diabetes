# .replit
# Run the full backend server in development
run = "npm run dev"

# Hide unnecessary files/folders from Replit file tree
hidden = [
  ".config",
  ".git",
  "generated-icon.png",
  "node_modules",
  "dist"
]

# Replit modules / language environment
modules = ["nodejs-20", "web", "postgresql-16"]

# Environment variables
[env]
PORT = "5000"

# Deployment settings
[deployment]
deploymentTarget = "static"      # For static site deployment
build = ["npm", "run", "build"]  # Build command
publicDir = "dist"               # Folder containing your built frontend

# Ports configuration
[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

# Nix environment version
[nix]
channel = "stable-24_05"